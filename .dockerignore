# Version control / editor
.git/
.gitignore
.claude/
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/

# Node (frontend is plain HTML/JS, no build step needed)
node_modules/
package.json
package-lock.json

# Secrets — never bake into the image; inject at runtime instead
.env
.env.*

# Runtime output / logs generated by the app itself
output/
audit_log.jsonl
audit_log.txt

# Large docs, media, and design assets not needed to run the app
*.docx
*.mp4
*.drawio
*.drawio.png
*.jpg
*.jpeg
capitalStatement-*
capitalSatement-*
high*level*Architecture*
high-level-architecture*
generate_hla_doc.js

# OS cruft
.DS_Store

# Docker itself
Dockerfile
.dockerignore
